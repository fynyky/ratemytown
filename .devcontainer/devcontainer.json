{
  "name": "Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/ratemytown",
  "forwardPorts": [3000, 5432, 6379, 9000, 9001],
  "portsAttributes": {
    "3000": {
      "label": "App",
      "onAutoForward": "openPreview"
    },
    "5432": {
      "label": "Postgres",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "9000": {
      "label": "MinIO S3 API",
      "onAutoForward": "silent"
    },
    "9001": {
      "label": "MinIO console",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "npm install && npm install -g @anthropic-ai/claude-code && curl -L https://fly.io/install.sh | sh",
  // flyctl installs to ~/.fly; put it on PATH for every shell and process in the
  // container (no ~/.bashrc patching needed). Auth comes from the FLY_API_TOKEN
  // Codespaces secret if set — see DEPLOY.md.
  "remoteEnv": {
    "FLYCTL_INSTALL": "/home/node/.fly",
    "PATH": "/home/node/.fly/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "claudeCode.allowDangerouslySkipPermissions": true,
        "claudeCode.initialPermissionMode": "bypassPermissions"
      }
    }
  }
}
