# Copy to .env and adjust as needed.
#
# NOTE: Inside the dev container you do NOT need a .env file — the Compose
# stack (.devcontainer/docker-compose.yml) injects the connection settings as
# real environment variables (pointing at the db/redis/minio service hosts),
# which take precedence over this file. These localhost defaults are for
# running the app on bare metal against your own services.
PORT=3000

# --- PostgreSQL ------------------------------------------------------------
DATABASE_URL=postgresql://node:node@localhost:5432/ratemytown

# --- Redis (cache + sessions) ----------------------------------------------
REDIS_URL=redis://localhost:6379

# Secret used to sign session cookies. Use a long random value in production.
SESSION_SECRET=dev-only-session-secret-change-me

# --- Blobstore (MinIO locally; any S3-compatible store in production) -------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ratemytown
S3_SECRET_KEY=ratemytown-dev-secret
S3_BUCKET=ratemytown-uploads

# Server-side secret salt used to hash NRICs (PRD §10 — privacy by design).
# In production this MUST be a long random secret and never committed.
NRIC_HASH_SALT=dev-only-salt-change-me
