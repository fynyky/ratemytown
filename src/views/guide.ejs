<% title = 'Rating guide — RateMyTown.sg' %>

<div class="appbar">
  <a class="iconbtn back" href="/" aria-label="Back">‹</a>
  <div class="bartitle">Rating guide</div>
  <div style="width:34px"></div>
</div>

<div class="scroll" style="padding-top:8px">
  <div class="sgtag">How to rate</div>
  <div class="abprose" style="margin-top:4px">Rate each area on how it actually feels to live here — not whether it's perfect, but whether the town council keeps things in good shape and takes residents seriously. Below is what each category covers, and what each star roughly means.</div>

  <% CATEGORIES.forEach(function(c){ %>
    <div class="guidecat"<% if (focus === c.key) { %> id="focus"<% } %>>
      <div class="scalelabel" style="font-size:15px"><%= c.label %></div>
      <div class="scaledesc" style="font-size:12.5px;margin:4px 0 10px"><%= c.desc %></div>
      <% c.scale.forEach(function(s){ %>
        <div class="scalerow">
          <span class="scalestars"><% for (var i=1;i<=5;i++){ %><span class="<%= i <= s.n ? 'on' : '' %>">★</span><% } %></span>
          <div>
            <div class="scalelabel"><%= s.label %></div>
            <div class="scaledesc"><%= s.desc %></div>
          </div>
        </div>
      <% }) %>
    </div>
  <% }) %>
</div>

<% if (focus) { %><script>document.getElementById('focus')&&document.getElementById('focus').scrollIntoView({block:'center'});</script><% } %>
