<% title = 'Review posted — RateMyTown.sg' %>

<div class="success">
  <div class="checkbadge"><span class="checkdisc">✓</span></div>
  <div class="successtit">Thank you for sharing</div>
  <div class="successsub">
    <% if (isNew) { %>Your review of <b><%= tc.name %></b> is now live and counts toward its rating.<% } else { %>Your review of <b><%= tc.name %></b> has been updated — your latest experience replaces the earlier one.<% } %>
    Honest experiences like yours help town councils see what's working and where to improve.
  </div>

  <%# The posted review, recapped with the exact card the town page renders. %>
  <div class="successreview">
    <div class="postedcard">
      <div>
        <div class="postedtc"><%= tc.name %></div>
        <div class="postedanon">Posted anonymously</div>
      </div>
    </div>
    <%- include('partials/review', { r: review }) %>
  </div>

  <div class="successbtns">
    <a class="btnf" href="/town/<%= tc.slug %>">See <%= tc.name %>'s page</a>
    <a class="btnghost" href="/">Back to leaderboard</a>
  </div>
</div>

