<% title = 'Rate your town — RateMyTown.sg' %>
<%- include('partials/top', { title }) %>

<% const f = form || {}; %>

<div class="appbar">
  <a class="iconbtn back" href="/" aria-label="Back">‹</a>
  <div class="bartitle">Rate your town</div>
  <div style="width:34px"></div>
</div>

<form method="post" action="/rate/verify">
  <div class="scroll" style="padding-top:8px">

    <% if (errors && errors.length) { %>
      <div class="errors">
        <ul><% errors.forEach(function(e){ %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <div class="field">
      <span class="flab">Which town council?</span>
      <div class="selectbox">
        <div class="tcpick">
          <span class="pin"></span>
          <select name="tc" aria-label="Town council">
            <% townCouncils.forEach(function(t){ %>
              <option value="<%= t.slug %>"<%= t.slug === selected ? ' selected' : '' %>><%= t.name %></option>
            <% }) %>
          </select>
        </div>
        <span class="chev">▾</span>
      </div>
      <div class="fhint">In the real app this is set automatically from your Singpass registered address.</div>
    </div>

    <div class="field">
      <span class="flab">Overall, how's living here?</span>
      <%- include('partials/starinput', { name: 'overall', value: parseInt(f.overall) || 0, cls: 'bigstars' }) %>
    </div>

    <div class="field">
      <span class="flab">Rate the specifics</span>
      <% CATEGORIES.forEach(function(c){ %>
        <div class="catrate">
          <div class="crleft">
            <span class="crname"><%= c.label %><a class="infoic2" href="/guide?cat=<%= c.key %>">i</a></span>
            <span class="crdesc"><%= c.desc %></span>
          </div>
          <%- include('partials/starinput', { name: c.key, value: parseInt(f[c.key]) || 0, cls: 'crstars' }) %>
        </div>
      <% }) %>
    </div>

    <div class="field">
      <span class="flab">Tell us more <span class="opt">· optional</span></span>
      <textarea class="ta" name="good_text" style="margin-bottom:10px" placeholder="What's been good? e.g. “Void deck is always clean and lifts are reliable…”"><%= f.good_text || '' %></textarea>
      <textarea class="ta" name="bad_text" placeholder="What could be better? e.g. “Drainage by the carpark floods after heavy rain…”"><%= f.bad_text || '' %></textarea>
    </div>

    <div class="cardnote">
      <span class="lk"></span>
      <span>Completely anonymous — we verify residency only when you post, and never store who you are.</span>
    </div>

    <button type="submit" class="btnf" style="margin-top:18px">Submit review</button>
  </div>
</form>

<%- include('partials/bottom') %>
