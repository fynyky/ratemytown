<% title = 'Rate your town — RateMyTown.sg' %>

<% const f = form || {}; %>

<div class="appbar">
  <a class="iconbtn back" href="/" aria-label="Back">‹</a>
  <div class="bartitle">Rate your town</div>
  <div style="width:34px"></div>
</div>

<%# `data-star-words` carries the shared 1-5 vocabulary once for the whole form;
    app.js names the level you picked as you tap. %>
<form method="post" action="/rate/verify" enctype="multipart/form-data" data-rateform data-star-words='<%= JSON.stringify(STAR_WORDS) %>'>
  <div class="scroll" style="padding-top:8px">

    <% if (errors && errors.length) { %>
      <div class="errors">
        <ul><% errors.forEach(function(e){ %><li><%= e %></li><% }) %></ul>
      </div>
    <% } %>

    <div class="field">
      <div class="selectbox">
        <select name="tc" aria-label="Town council" required>
          <option value="" disabled<%= selected ? '' : ' selected' %>>Choose your town…</option>
          <% townCouncils.forEach(function(t){ %>
            <option value="<%= t.slug %>"<%= t.slug === selected ? ' selected' : '' %>><%= t.name %></option>
          <% }) %>
        </select>
        <span class="chev">▾</span>
      </div>
    </div>

    <div class="field">
      <div class="cardfield">
        <span class="flab">Overall, how's living here?</span>
        <div class="overallrate">
          <%- include('partials/starinput', { name: 'overall', value: parseInt(f.overall) || 0, cls: 'bigstars' }) %>
          <span class="starword" data-star-word-for="overall"><%= STAR_WORDS[parseInt(f.overall) || 0] %></span>
        </div>
      </div>
    </div>

    <div class="field">
      <span class="flab">Rate the specifics <span class="opt">· optional — rate only what you know</span></span>
      <div class="cardlist">
        <% CATEGORIES.forEach(function(c){ const v = parseInt(f[c.key]) || 0; %>
          <div class="catrate">
            <div class="crhead">
              <span class="crname"><%= c.label %><a class="infoic2" href="/guide?cat=<%= c.key %>" data-guide="<%= c.key %>">i</a></span>
              <span class="starword" data-star-word-for="<%= c.key %>"><%= STAR_WORDS[v] %></span>
            </div>
            <span class="crdesc"><%= c.desc %></span>
            <%- include('partials/starinput', { name: c.key, value: v, cls: 'crstars' }) %>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="field">
      <span class="flab">Tell us more <span class="opt">· optional</span></span>
      <textarea class="ta" name="good_text" style="margin-bottom:10px" placeholder="What's been good? e.g. “Void deck is always clean and lifts are reliable…”"><%= f.good_text || '' %></textarea>
      <textarea class="ta" name="bad_text" placeholder="What could be better? e.g. “Drainage by the carpark floods after heavy rain…”"><%= f.bad_text || '' %></textarea>
    </div>

    <div class="field">
      <span class="flab">Add photos <span class="opt">· optional</span></span>
      <div class="photogrid" data-photogrid>
        <input type="file" name="photos" accept="image/*" multiple hidden data-photo-input>
        <button type="button" class="phototile photoadd" data-photo-add aria-label="Add photo">＋</button>
      </div>
      <span class="photoinput-files" data-photo-files>Up to 4 photos · JPG, PNG, WebP or GIF · 5MB max each</span>
    </div>

    <div class="cardnote">
      <span class="ok">✓</span>
      <span><b>Anonymous, but verified.</b> Residency is confirmed via Singpass when you submit — your identity is never stored with the review.</span>
    </div>

    <%# Enabled by default so the form still submits without JS (the server
        validates town + overall either way); app.js gates it and says why. %>
    <button type="submit" class="btnf" style="margin-top:18px" data-submit-gate>Submit review</button>
  </div>
</form>

<%- include('partials/guide-sheet') %>
