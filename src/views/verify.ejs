<% title = 'Verify with Singpass — RateMyTown.sg' %>

<%# The verify step is a bottom-sheet modal (mock 04): the resident's rating is
    shown dimmed and blurred behind, with the Singpass sheet slid up over it. %>
<%- include('partials/appbar', { heading: 'Rate your town', back: '/rate?tc=' + data.tc }) %>

<div class="scroll ratebackdrop" aria-hidden="true">
  <div class="field">
    <div class="selectbox">
      <span class="tcval"><%= tc.name %></span>
      <span class="chev">▾</span>
    </div>
  </div>
  <div class="field">
    <div class="cardfield">
      <span class="flab">Overall, how's living here?</span>
      <div class="overallrate">
        <div class="bigstars"><% for (var i=1;i<=5;i++){ %><span class="star<%= i <= data.overall ? ' sel' : '' %>">★</span><% } %></div>
        <span class="starword"><%= STAR_WORDS[data.overall] || '' %></span>
      </div>
    </div>
  </div>
  <div class="field">
    <span class="flab">Rate the specifics <span class="opt">· optional</span></span>
    <div class="cardlist">
      <% CATEGORIES.forEach(function(c){ const v = data.cats[c.key] || 0; %>
        <div class="catrate">
          <div class="crhead">
            <span class="crname"><%= c.label %></span>
            <span class="starword"><%= STAR_WORDS[v] || '' %></span>
          </div>
          <span class="crstars"><% for (var i=1;i<=5;i++){ %><span class="star<%= i <= v ? ' sel' : '' %>">★</span><% } %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<div class="modal">
  <a class="modal-scrim" href="/rate?tc=<%= data.tc %>" aria-label="Close and go back"></a>
  <div class="sheet" role="dialog" aria-modal="true" aria-label="Verify with Singpass">
    <a class="grabhit" href="/rate?tc=<%= data.tc %>" aria-label="Close and go back"><span class="grab"></span></a>

    <div class="sheettit">One last step — let's confirm you live here</div>
    <div class="sheetsub">Your review of <b><%= tc.name %></b> is ready. Before it goes live, we verify your residency with Singpass. Here's why it matters:</div>

    <div class="whyrow">
      <div class="whyic">✓</div>
      <div>
        <div class="whytit">It keeps reviews real</div>
        <div class="whytxt">Only people who actually live in the estate can post — so scores stay trustworthy and can't be gamed.</div>
      </div>
    </div>
    <div class="whyrow">
      <div class="whyic">✓</div>
      <div>
        <div class="whytit">Your review stays anonymous</div>
        <div class="whytxt">We confirm you live here only at the moment you post. Your identity is never attached to your review or stored afterwards.</div>
      </div>
    </div>
    <div class="whyrow">
      <div class="whyic">✓</div>
      <div>
        <div class="whytit">One resident, one voice</div>
        <div class="whytxt">Verification means no duplicate or fake reviews stacking the deck either way.</div>
      </div>
    </div>

    <% if (error) { %><div class="errors" style="margin:10px 0"><%= error %></div><% } %>

    <% if (data.photoKeys && data.photoKeys.length) { %>
      <div class="nriclabel"><%= data.photoKeys.length %> photo<%= data.photoKeys.length > 1 ? 's' : '' %> attached</div>
    <% } %>

    <form method="post" action="/rate/submit">
      <%# Review data is held in the Redis-backed session draft, not in the form. %>
      <div class="nriclabel">Demo only — enter any valid NRIC/FIN to simulate Singpass (e.g. S1234567A)</div>
      <input class="nricinput" name="nric" placeholder="S1234567A" autocomplete="off" value="<%= nricValue %>">

      <button type="submit" class="spbtn"><span class="spd"></span> Verify with Singpass</button>
    </form>
    <div class="sheetnote">We never store your NRIC. The moment you verify, it's turned into an anonymous code that can't be traced back to you — and only that code is kept.</div>
  </div>
</div>
