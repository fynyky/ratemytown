<% title = tc.name + ' — RateMyTown.sg' %>

<%
  const heroReview = reviews.find(function(r){ return r.good_text; });
  // Every category rank map covers all town councils, so any one gives the total.
  const totalTcs = Object.keys(ranks[CATEGORIES[0].key] || {}).length;
%>

<div class="scroll" style="padding:0">
  <div class="hero">
    <div class="tilephoto" style="background-image:url(/towns/<%= tc.slug %>.jpg)"></div>
    <div class="tilefade"></div>
    <a class="iconbtn back" href="/" aria-label="Back">‹</a>
    <% if (heroReview) { %>
      <div class="heroquote">
        <div class="q">“<%= heroReview.good_text %>”</div>
        <div class="by">From a verified resident</div>
      </div>
    <% } %>
  </div>

  <%# Post-hero content is centred to the same reading column as every other screen. %>
  <div class="townbody">
    <div style="padding-top:16px">
      <div class="parea"><%= tc.area %></div>
      <div class="tcnamed" style="font-size:22px"><%= tc.name %></div>
      <% if (tc.suppressed) { %>
        <div class="norating" style="margin-top:8px">
          Not enough verified reviews yet — <%= tc.review_count %> so far. Scores appear once there are enough to be representative.
        </div>
      <% } else { %>
        <div style="display:flex;align-items:center;gap:9px;margin-top:8px">
          <span class="scorebig"><%= h.fmtScore(tc.overall) %></span>
          <%- include('partials/stars', { score: tc.overall, size: 17 }) %>
          <span style="font-size:12px;color:var(--mut)">· <%= h.fmtCount(tc.review_count) %> reviews</span>
        </div>
      <% } %>
    </div>

    <% if (!tc.suppressed) { %>
      <div style="padding-top:16px">
        <div class="catgrid">
          <% CATEGORIES.forEach(function(c){
               const score = tc.scores[c.key];
               const rk = ranks[c.key] && ranks[c.key][tc.id]; %>
            <div class="catcell">
              <div class="catcell-lab"><%= c.short %><a class="catgi" href="/guide?cat=<%= c.key %>" data-guide="<%= c.key %>">i</a></div>
              <div class="catcell-val"><%= h.fmtScore(score) %></div>
              <% if (rk) { %><div class="catcell-rank">#<%= rk.rank %></div><% } %>
            </div>
          <% }) %>
        </div>
        <div class="ranknote">Ranks are out of <%= totalTcs %> town councils</div>
      </div>

      <div class="section">
        <div class="sgtag">In residents' words</div>
        <div class="summary"><%= tc.blurb %></div>
      </div>
    <% } %>

    <div style="padding:8px 0 24px">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0 4px;border-top:1px solid #ece6da">
        <div class="sectit" style="margin:0">Resident reviews</div>
        <div style="font-size:11.5px;color:var(--green);font-weight:600">Most recent</div>
      </div>

      <% if (reviews.length === 0) { %>
        <div class="rvw" style="color:var(--mut)">No reviews yet. Be the first verified resident to share your experience.</div>
      <% } %>

      <% reviews.forEach(function(r){
           const tags = h.reviewTags(r, CATEGORIES); %>
        <div class="rvw">
          <div class="rvwh">
            <%- include('partials/stars', { score: r.overall, size: 14 }) %>
            <span class="rvwmeta">
              <span class="vchip">Verified</span>
              <span class="vdot">·</span>
              <span class="rvwt"><%= h.timeAgo(r.created_at) %></span>
            </span>
          </div>
          <% if (r.good_text) { %><div class="rvwb"><%= r.good_text %></div><% } %>
          <% if (r.bad_text) { %><div class="rvwb"><%= r.bad_text %></div><% } %>
          <% if (r.photos && r.photos.length) { %>
            <div class="rvwphotos"><% r.photos.forEach(function(k){ %><img class="rvwphoto" src="/uploads/<%= k %>" alt="Resident photo" loading="lazy"><% }) %></div>
          <% } %>
          <% if (tags.length) { %>
            <div class="rvwtags"><% tags.forEach(function(t){ %><span class="rvwtag"><%= t %></span><% }) %></div>
          <% } %>
        </div>
      <% }) %>

      <a class="btnf" style="margin-top:18px" href="/rate?tc=<%= tc.slug %>">Rate <%= tc.name %></a>
    </div>
  </div>
</div>

<%- include('partials/guide-sheet') %>
