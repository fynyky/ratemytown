<% title = tc.name + ' — RateMyTown.sg' %>

<%
  // Hero slideshow: the town's cover photo leads, then every review photo in
  // recency order, each carrying its own review's quote over the image.
  const slides = [{ img: '/towns/' + tc.slug + '.jpg', quote: null }];
  reviews.forEach(function(r){
    (r.photos || []).forEach(function(k){
      slides.push({ img: '/uploads/' + k, quote: r.good_text || null });
    });
  });
  // The rank map covers every town council, so its size is the total.
  const totalTcs = Object.keys(ranks.overall).length;
%>

<div class="scroll" style="padding:0">
  <%# Resident photos (every slide after the cover) keep their real aspect
      ratio on a black backdrop; clicking any slide opens the lightbox. %>
  <div class="hero" data-hero>
    <% slides.forEach(function(s, i){ %>
      <div class="heroslide<%= i === 0 ? ' on' : '' %><%= i > 0 ? ' photo' : '' %>" data-img="<%= s.img %>">
        <div class="tilephoto" style="background-image:url(<%= s.img %>)"></div>
        <% if (s.quote) { %>
          <div class="heroquote">
            <div class="q">“<%= s.quote %>”</div>
            <div class="by">From a resident review</div>
          </div>
        <% } %>
      </div>
    <% }) %>
    <a class="backpill" href="/">Back</a>
    <% if (slides.length > 1) { %>
      <button type="button" class="heroarrow prev" data-hero-prev aria-label="Previous photo">‹</button>
      <button type="button" class="heroarrow next" data-hero-next aria-label="Next photo">›</button>
    <% } %>
  </div>

  <%# Post-hero content is centred to the same reading column as every other screen. %>
  <div class="townbody">
    <div style="padding-top:16px">
      <div class="parea"><%= tc.area %></div>
      <div class="tcnamed" style="font-size:28px"><%= tc.name %></div>
      <% if (tc.suppressed) { %>
        <div class="norating" style="margin-top:8px">
          Not enough verified reviews yet — <%= tc.review_count %> so far. Scores appear once there are enough to be representative.
        </div>
      <% } else { %>
        <% const overallRank = ranks.overall[tc.id] %>
        <div style="display:flex;align-items:baseline;gap:8px;margin-top:4px">
          <span class="scorebig"><%= h.fmtScore(tc.overall) %></span>
          <%- include('partials/stars', { score: tc.overall, size: 16 }) %>
          <span style="font-size:13px;color:var(--mut)">
            <% if (overallRank) { %>#<%= overallRank %> of <%= totalTcs %> · <% } %><%= h.fmtCount(tc.review_count) %> reviews
          </span>
        </div>
        <%# Podium awards, from the same rank map as the catbar chips below so
            the two can never disagree — including the "no score, no rank"
            guard. Same badges as the leaderboard. %>
        <% const awards = [['overall', 'Overall', tc.overall], ...CATEGORIES.map((c) => [c.key, c.short, tc.scores[c.key]])]
             .map(([key, label, score]) => ({ label, rank: score == null ? null : ranks[key][tc.id] }))
             .filter((a) => a.rank && a.rank <= 3) %>
        <% if (awards.length) { %>
          <div class="townawards">
            <% awards.forEach(function(a){ %>
              <%- include('partials/rankbadge', { rank: a.rank, label: a.label }) %>
            <% }) %>
          </div>
        <% } %>
      <% } %>
    </div>

    <% if (!tc.suppressed) { %>
      <div style="padding-top:16px">
        <div class="catbars">
          <% CATEGORIES.forEach(function(c){
               const score = tc.scores[c.key];
               // A rank is only meaningful where there is a score to rank.
               const rk = score == null ? null : ranks[c.key][tc.id]; %>
            <div class="catbar">
              <span class="catbar-lab"><%= c.label %><a class="catgi" href="/guide?cat=<%= c.key %>" data-guide="<%= c.key %>">i</a></span>
              <span class="catbar-track"><span class="catbar-fill" style="width:<%= h.starPct(score) %>"></span></span>
              <span class="catbar-val"><%= h.fmtScore(score) %></span>
              <span class="catbar-rank<%= rk && rk <= 3 ? ' top' : '' %>"><% if (rk) { %>#<%= rk %><% } %></span>
            </div>
          <% }) %>
        </div>
        <div class="ranknote">Ranks are out of <%= totalTcs %> town councils</div>
      </div>

      <div class="section">
        <div class="sgtag">In residents' words</div>
        <div class="summary"><%= tc.blurb %></div>
      </div>
    <% } %>

    <div style="padding:8px 0 24px">
      <div style="display:flex;align-items:baseline;justify-content:space-between;padding:8px 0 10px">
        <div class="sectit" style="margin:0">Resident reviews</div>
        <%# A real control (app.js reorders the cards client-side); without JS
            it stays on the server's most-recent order. %>
        <label class="sortlab">
          <select class="sortsel" data-review-sort aria-label="Sort reviews">
            <option value="recent">Most recent</option>
            <option value="high">Highest rated</option>
            <option value="low">Lowest rated</option>
          </select>
          <span aria-hidden="true">▾</span>
        </label>
      </div>

      <% if (reviews.length === 0) { %>
        <div class="rvw" style="color:var(--mut)">No reviews yet. Be the first verified resident to share your experience.</div>
      <% } %>

      <div data-reviews>
        <% reviews.forEach(function(r){ %>
          <%- include('partials/review', { r: r }) %>
        <% }) %>
      </div>

      <a class="btnf" style="margin-top:16px" href="/rate?tc=<%= tc.slug %>">★&nbsp; Rate <%= tc.name %></a>
    </div>
  </div>
</div>

<%# Lightbox: clicking any hero slide opens the current photo full-screen.
    The arrows share the hero's data attributes, so one handler in app.js
    drives both; hidden until opened, so no-JS visitors never see it. %>
<div class="lightbox" data-lightbox hidden>
  <button type="button" class="lightbox-scrim" data-lightbox-close aria-label="Close photo viewer"></button>
  <figure class="lightbox-figure">
    <img class="lightbox-img" data-lightbox-img alt="Photo of <%= tc.name %>">
    <%# Mirrors the current slide's quote (app.js); hidden on the cover photo,
        which carries none. %>
    <figcaption class="heroquote lightbox-quote" data-lightbox-quote hidden>
      <div class="q" data-lightbox-quote-text></div>
      <div class="by">From a resident review</div>
    </figcaption>
  </figure>
  <button type="button" class="lightbox-x" data-lightbox-close aria-label="Close photo viewer">✕</button>
  <% if (slides.length > 1) { %>
    <button type="button" class="heroarrow prev" data-hero-prev aria-label="Previous photo">‹</button>
    <button type="button" class="heroarrow next" data-hero-next aria-label="Next photo">›</button>
  <% } %>
</div>

<%- include('partials/guide-sheet') %>
