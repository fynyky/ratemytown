<%# interactive star input: params `name`, `value` (0-5), `cls` (extra class) %>
<span class="starrate <%= typeof cls !== 'undefined' ? cls : 'crstars' %>" data-starinput role="radiogroup" aria-label="<%= name %> rating">
  <input type="hidden" name="<%= name %>" value="<%= value || '' %>">
  <% for (var i = 1; i <= 5; i++) { %>
    <span class="star<%= (value && i <= value) ? ' on sel' : '' %>" data-val="<%= i %>" role="radio" aria-label="<%= i %> star" aria-checked="<%= (value && i === value) ? 'true' : 'false' %>" tabindex="<%= (value ? i === value : i === 1) ? '0' : '-1' %>">★</span>
  <% } %>
</span>
