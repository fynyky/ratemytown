<%# Rank badge — a solid laurel-wreath award mark with the rank on a medal
    disc, plus (optionally) a plaque sticking out the right naming what the
    prize is for ("Overall" or the sorted category). Dense overlapping
    leaves merge into one solid band so the badge reads as a single chunk
    over busy photos; a stroked white under-copy of the whole silhouette
    gives it a halo. The left side is the right mirrored, and the stems
    cross at the bottom. Geometry lives in <defs> and is styled from the
    <use> elements because CSS classes don't reliably reach <use> shadow
    clones. Colors come from --medal/--leaf, set per rank in styles.css. %>
<% const tag = typeof label !== 'undefined' && label ? label : null %>
<%# Def ids carry rank + label so the many badges on a leaderboard never
    cross-reference a differently-shaped silhouette (href resolves
    document-wide, and only the labeled variant has the plaque). %>
<% const uid = rank + (tag ? '-' + tag.toLowerCase().replace(/[^a-z0-9]+/g, '') : '') %>
<svg class="rankbadge r<%= rank %><%= tag ? ' haslabel' : '' %>" viewBox="0 0 <%= tag ? 96 : 44 %> 40" role="img" aria-label="Ranked #<%= rank %><%= tag ? ' for ' + tag : '' %>">
  <defs>
    <path id="rblf<%= uid %>" d="M23.4 6.8 Q19.5 11.6 14 6.8 Q19.5 2 23.4 6.8 Z" transform="rotate(12 22 6.8)"/>
    <g id="rbwr<%= uid %>">
      <% if (tag) { %><rect x="28" y="14.2" width="62" height="13.6" rx="4"/><% } %>
      <% ['', 'translate(44 0) scale(-1 1)'].forEach(function(mirror){ %>
        <g<%- mirror ? ' transform="' + mirror + '"' : '' %>>
          <% [50, 68, 86, 104, 122, 140, 158, 176].forEach(function(angle){ %>
            <use href="#rblf<%= uid %>" transform="rotate(<%= angle %> 22 21)"/>
          <% }) %>
        </g>
      <% }) %>
    </g>
  </defs>
  <use href="#rbwr<%= uid %>" style="fill:#fff;stroke:#fff;stroke-width:2.2"/>
  <use href="#rbwr<%= uid %>" style="fill:var(--leaf)"/>
  <circle class="disc" cx="22" cy="21" r="11"/>
  <text class="num" x="22" y="21" text-anchor="middle" dy=".37em"><%= rank %></text>
  <% if (tag) { %><text class="tagtext" x="59.5" y="21" text-anchor="middle" dy=".36em"><%= tag %></text><% } %>
</svg>
