<%# Rank badge — a laurel award wreath with the rank on a medal disc.
    One leaf <path> is stamped along an arc on each side (the left side is
    the right mirrored); the wreath is open at the top and the stems cross
    at the bottom. The leaf is styled inline because CSS classes don't
    reliably reach <use> shadow clones. Colors come from --medal/--leaf,
    set per rank in styles.css. %>
<svg class="rankbadge r<%= rank %>" viewBox="0 0 44 40" role="img" aria-label="Ranked #<%= rank %>">
  <defs>
    <path id="rblf<%= rank %>" style="fill:var(--leaf);stroke:#fff;stroke-width:.8;paint-order:stroke"
      d="M22.6 5.5 Q19.4 9.3 14.6 5.5 Q19.4 1.7 22.6 5.5 Z" transform="rotate(20 22 5.5)"/>
  </defs>
  <% ['', 'translate(44 0) scale(-1 1)'].forEach(function(mirror){ %>
    <g<%- mirror ? ' transform="' + mirror + '"' : '' %>>
      <% [58, 86, 114, 142, 168].forEach(function(angle){ %>
        <use href="#rblf<%= rank %>" transform="rotate(<%= angle %> 22 21)"/>
      <% }) %>
    </g>
  <% }) %>
  <circle class="disc" cx="22" cy="21" r="10.5"/>
  <text class="num" x="22" y="21" text-anchor="middle" dy=".37em"><%= rank %></text>
</svg>
