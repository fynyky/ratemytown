<% title = 'RateMyTown.sg — Town council leaderboard' %>

<div class="appbar home">
  <div class="brandrow">
    <div class="brandmark">★</div>
    <div>
      <div class="wordmark">RateMyTown<span class="sg">.sg</span></div>
      <div class="appsub">Good feedback makes better towns</div>
    </div>
  </div>
  <a class="aboutpill" href="/about">About</a>
</div>

<%
  // Overall, then one chip per category — derived from the shared category list.
  const sortChips = [['overall', 'Overall'], ...CATEGORIES.map((c) => [c.key, c.label])];
  // Podium badges: over the photo for the top 3 by the current sort, and on each
  // category cell for the top 3 in that category.
  const topBySort = h.topRanks(leaderboard, sort);
  const topByCat = Object.fromEntries(CATEGORIES.map((c) => [c.key, h.topRanks(leaderboard, c.key)]));
%>
<div class="chiprow">
  <% sortChips.forEach(function(c){ %>
    <a class="chip<%= sort === c[0] ? ' on' : '' %>" href="/?sort=<%= c[0] %>"><%= c[1] %></a>
  <% }) %>
</div>

<div class="scroll" style="padding-top:4px">

  <% leaderboard.forEach(function(r){ %>
    <% if (r.suppressed) { %>
      <a class="lbrow flat" href="/town/<%= r.slug %>">
        <div class="tcnamed"><%= r.name %></div>
        <div class="norating">Not enough verified reviews yet · <%= r.review_count %> so far</div>
      </a>
    <% } else { %>
      <% const rank = topBySort.get(r.id) %>
      <a class="lbrow" href="/town/<%= r.slug %>">
        <div class="lbthumb" style="background-image:url(/towns/<%= r.slug %>.jpg)">
          <% if (rank) { %>
            <div class="rankbadge r<%= rank %>" title="#<%= rank %>"><%= rank %></div>
          <% } %>
        </div>
        <div class="lbbody">
          <div class="lbtop">
            <div class="tcname"><%= r.name %></div>
            <div class="ovr">
              <span class="ovrnum"><%= h.fmtScore(r.overall) %></span>
              <%- include('partials/stars', { score: r.overall, size: 13 }) %>
            </div>
          </div>
          <div class="subs">
            <% CATEGORIES.forEach(function(c){
                 const cr = topByCat[c.key].get(r.id); %>
              <div class="sub<%= sort === c.key ? ' on' : '' %>">
                <div class="sublab"><%= c.short %></div>
                <div class="subv">
                  <%= h.fmtScore(r.scores[c.key]) %><% if (cr) { %><span class="subrank r<%= cr %>" title="#<%= cr %> for <%= c.label %>"><%= cr %></span><% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </a>
    <% } %>
  <% }) %>
</div>

<div class="ctabar">
  <a class="ctabtn" href="/rate"><span>★</span> Rate your town</a>
</div>

