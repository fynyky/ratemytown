<% title = 'RateMyTown.sg — Town council leaderboard' %>

<div class="appbar">
  <div class="brandrow">
    <div class="brandmark">★</div>
    <div>
      <div class="wordmark">RateMyTown<span class="sg">.sg</span></div>
      <div class="appsub">Good feedback makes better towns</div>
    </div>
  </div>
  <a class="aboutpill" href="/about">About</a>
</div>

<%
  // Overall, then one chip per category — derived from the shared category list.
  const sortChips = [['overall', 'Overall'], ...CATEGORIES.map((c) => [c.key, c.label])];
  // Podium badges over the photo: every top-3 finish — overall and in each
  // category — earns a badge with a plaque naming the prize. A town holding
  // several awards stacks them on its photo. Rank every metric once here (one
  // topRanks pass per key), then each row reads its own rank by id.
  const rankMaps = { overall: h.topRanks(leaderboard, 'overall') };
  CATEGORIES.forEach((c) => { rankMaps[c.key] = h.topRanks(leaderboard, c.key); });
%>
<div class="chiprow">
  <% sortChips.forEach(function(c){ %>
    <a class="chip<%= sort === c[0] ? ' on' : '' %>" href="/?sort=<%= c[0] %>"><%= c[1] %></a>
  <% }) %>
</div>

<div class="scroll" style="padding-top:4px">

  <% leaderboard.forEach(function(r){ %>
    <% if (r.suppressed) { %>
      <a class="lbrow flat" href="/town/<%= r.slug %>">
        <div class="tcnamed"><%= r.name %></div>
        <div class="norating">Not enough verified reviews yet · <%= r.review_count %> so far</div>
      </a>
    <% } else { %>
      <% const rowAwards = h.awardsFor(CATEGORIES, (key) => rankMaps[key].get(r.id)) %>
      <%# The headline score is whichever metric is being ranked by, so the sort
          re-emphasizes as well as re-orders. %>
      <% const activeScore = sort === 'overall' ? r.overall : r.scores[sort] %>
      <a class="lbrow" href="/town/<%= r.slug %>">
        <div class="lbthumb" style="background-image:url(/towns/<%= r.slug %>.jpg)">
          <% if (rowAwards.length) { %>
            <div class="rankbadges">
              <% rowAwards.forEach(function(a){ %>
                <%- include('partials/rankbadge', { rank: a.rank, label: a.label }) %>
              <% }) %>
            </div>
          <% } %>
        </div>
        <div class="lbbody">
          <div class="lbtop">
            <div class="tcname"><%= r.name %></div>
            <div class="ovr">
              <div class="ovrline">
                <span class="ovrnum"><%= h.fmtScore(activeScore) %></span>
                <%- include('partials/stars', { score: activeScore, size: 13 }) %>
              </div>
            </div>
          </div>
          <div class="subs">
            <% CATEGORIES.forEach(function(c){ %>
              <div class="sub<%= sort === c.key ? ' on' : '' %>">
                <div class="sublab"><%= c.short %></div>
                <div class="subv"><%= h.fmtScore(r.scores[c.key]) %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </a>
    <% } %>
  <% }) %>
</div>

<div class="ctabar">
  <a class="ctabtn" href="/rate"><span>★</span> Rate your town</a>
</div>

