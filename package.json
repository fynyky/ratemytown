{
  "name": "ratemytown",
  "version": "0.1.0",
  "description": "RateMyTown.sg — a review & accountability platform for Singapore town councils",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node src/db/init.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/init.js && node src/db/seed.js"
  },
  "dependencies": {
    "connect-redis": "^7.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "minio": "^8.0.1",
    "multer": "^2.0.0",
    "pg": "^8.12.0",
    "redis": "^4.7.0"
  }
}
