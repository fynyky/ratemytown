#!/usr/bin/env bash
#
# Local dev services manager for RateMyTown.sg.
# Provisions and runs the three backing services natively (no Docker required):
#   - PostgreSQL  (relational data)        localhost:5432
#   - Redis       (cache + sessions)       localhost:6379
#   - MinIO       (S3-compatible blobstore) localhost:9000  console :9001
#
# Usage: scripts/dev {setup|start|stop|status|restart}
#   setup    install missing binaries, provision DB role/database, start everything
#   start    start any service that isn't running
#   stop     stop Redis and MinIO (Postgres cluster is left running)
#   status   show what's up
#
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA="$ROOT/.devdata"
mkdir -p "$DATA/redis" "$DATA/minio"

# --- config (keep in sync with .env / src/config.js) -----------------------
PG_DB="ratemytown"
PG_USER="node"
PG_PASS="node"
REDIS_PORT="6379"
MINIO_USER="ratemytown"
MINIO_PASS="ratemytown-dev-secret"
MINIO_BUCKET="ratemytown-uploads"

c_green=$'\033[32m'; c_red=$'\033[31m'; c_dim=$'\033[2m'; c_off=$'\033[0m'
ok()   { echo "  ${c_green}✓${c_off} $*"; }
warn() { echo "  ${c_red}✗${c_off} $*"; }
info() { echo "${c_dim}$*${c_off}"; }

pg_ver() { ls /etc/postgresql 2>/dev/null | sort -n | tail -1; }
as_postgres() { sudo -n bash -c "runuser -u postgres -- $*"; }

# ---------------------------------------------------------------------------
install_binaries() {
  local need_apt=0
  command -v pg_ctlcluster >/dev/null || need_apt=1
  command -v redis-server  >/dev/null || need_apt=1
  if [ "$need_apt" = 1 ]; then
    info "Installing system packages (postgresql, redis-server)…"
    sudo apt-get update -qq
    command -v pg_ctlcluster >/dev/null || sudo apt-get install -y -qq postgresql postgresql-contrib
    command -v redis-server  >/dev/null || sudo apt-get install -y -qq redis-server
  fi
  if ! command -v minio >/dev/null; then
    info "Downloading MinIO server binary…"
    sudo curl -fsSL https://dl.min.io/server/minio/release/linux-amd64/minio -o /usr/local/bin/minio
    sudo chmod +x /usr/local/bin/minio
  fi
  if ! command -v mc >/dev/null; then
    info "Downloading MinIO client (mc)…"
    sudo curl -fsSL https://dl.min.io/client/mc/release/linux-amd64/mc -o /usr/local/bin/mc
    sudo chmod +x /usr/local/bin/mc
  fi
}

# --- Postgres --------------------------------------------------------------
pg_running() { pg_isready -h localhost -p 5432 >/dev/null 2>&1; }

start_pg() {
  if pg_running; then ok "Postgres already running (5432)"; return; fi
  sudo -n pg_ctlcluster "$(pg_ver)" main start >/dev/null 2>&1 || true
  for _ in $(seq 1 20); do pg_running && break; sleep 0.3; done
  pg_running && ok "Postgres started (5432)" || { warn "Postgres failed to start"; return 1; }
}

provision_pg() {
  start_pg
  as_postgres "psql -tc \"SELECT 1 FROM pg_roles WHERE rolname='$PG_USER'\"" | grep -q 1 \
    || as_postgres "psql -c \"CREATE ROLE $PG_USER LOGIN SUPERUSER PASSWORD '$PG_PASS'\"" >/dev/null
  as_postgres "psql -tc \"SELECT 1 FROM pg_database WHERE datname='$PG_DB'\"" | grep -q 1 \
    || as_postgres "createdb -O $PG_USER $PG_DB" >/dev/null
  ok "Postgres role '$PG_USER' and database '$PG_DB' ready"
}

# --- Redis -----------------------------------------------------------------
redis_running() { redis-cli -p "$REDIS_PORT" ping >/dev/null 2>&1; }

start_redis() {
  if redis_running; then ok "Redis already running ($REDIS_PORT)"; return; fi
  redis-server --daemonize yes --port "$REDIS_PORT" \
    --dir "$DATA/redis" --pidfile "$DATA/redis/redis.pid" \
    --logfile "$DATA/redis/redis.log" --save '' --appendonly no >/dev/null
  for _ in $(seq 1 20); do redis_running && break; sleep 0.2; done
  redis_running && ok "Redis started ($REDIS_PORT)" || { warn "Redis failed to start"; return 1; }
}

stop_redis() {
  redis_running && redis-cli -p "$REDIS_PORT" shutdown nosave >/dev/null 2>&1 || true
  ok "Redis stopped"
}

# --- MinIO -----------------------------------------------------------------
minio_running() { curl -fsS http://localhost:9000/minio/health/ready >/dev/null 2>&1; }

start_minio() {
  if minio_running; then ok "MinIO already running (9000)"; return; fi
  MINIO_ROOT_USER="$MINIO_USER" MINIO_ROOT_PASSWORD="$MINIO_PASS" \
    nohup minio server "$DATA/minio" --quiet \
    --address :9000 --console-address :9001 \
    > "$DATA/minio/minio.log" 2>&1 &
  echo $! > "$DATA/minio/minio.pid"
  for _ in $(seq 1 40); do minio_running && break; sleep 0.25; done
  minio_running && ok "MinIO started (api :9000, console :9001)" || { warn "MinIO failed to start (see $DATA/minio/minio.log)"; return 1; }
}

provision_minio() {
  start_minio
  if command -v mc >/dev/null; then
    mc alias set rmt-local http://localhost:9000 "$MINIO_USER" "$MINIO_PASS" >/dev/null 2>&1 || true
    mc mb --ignore-existing "rmt-local/$MINIO_BUCKET" >/dev/null 2>&1 || true
  fi
  ok "MinIO bucket '$MINIO_BUCKET' ready"
}

stop_minio() {
  if [ -f "$DATA/minio/minio.pid" ]; then
    kill "$(cat "$DATA/minio/minio.pid")" >/dev/null 2>&1 || true
    rm -f "$DATA/minio/minio.pid"
  fi
  ok "MinIO stopped"
}

# ---------------------------------------------------------------------------
case "${1:-status}" in
  setup)
    echo "Setting up local dev services…"
    install_binaries
    provision_pg
    start_redis
    provision_minio
    echo "Done. Next: ${c_green}npm run db:reset${c_off} then ${c_green}npm start${c_off}"
    ;;
  start)
    echo "Starting services…"
    start_pg; start_redis; start_minio
    ;;
  stop)
    echo "Stopping services…"
    stop_redis; stop_minio
    info "(Postgres cluster left running; stop with: sudo pg_ctlcluster $(pg_ver) main stop)"
    ;;
  restart)
    stop_redis; stop_minio; start_pg; start_redis; start_minio
    ;;
  status)
    echo "Service status:"
    pg_running    && ok "Postgres  localhost:5432" || warn "Postgres  not running"
    redis_running && ok "Redis     localhost:6379" || warn "Redis     not running"
    minio_running && ok "MinIO     localhost:9000 (console :9001)" || warn "MinIO     not running"
    ;;
  *)
    echo "Usage: scripts/dev {setup|start|stop|restart|status}"; exit 1
    ;;
esac
